{% extends '@admin/layout/base.html.twig' %}

{% block title %}Dashboard — CoreCart Admin{% endblock %}

{% block content %}
<h1 class="cc-mb-4">Dashboard</h1>

<div class="cc-grid cc-grid-4 cc-mb-8">
    <div class="cc-card cc-card-body">
        <div class="cc-text-muted cc-text-sm">Orders today</div>
        <div class="cc-stat">{{ stats.orders_today|default(0) }}</div>
    </div>
    <div class="cc-card cc-card-body">
        <div class="cc-text-muted cc-text-sm">Revenue today</div>
        <div class="cc-stat">{{ stats.revenue_today|default('0.00') }} $</div>
    </div>
    <div class="cc-card cc-card-body">
        <div class="cc-text-muted cc-text-sm">New customers</div>
        <div class="cc-stat">{{ stats.customers_today|default(0) }}</div>
    </div>
    <div class="cc-card cc-card-body">
        <div class="cc-text-muted cc-text-sm">Low stock products</div>
        <div class="cc-stat">{{ stats.low_stock|default(0) }}</div>
    </div>
</div>

<h2 class="cc-mb-4">Recent orders</h2>
{% if recent_orders is defined and recent_orders|length > 0 %}
<table class="cc-table">
    <thead>
        <tr>
            <th>ID</th>
            <th>Customer</th>
            <th>Status</th>
            <th>Total</th>
            <th>Date</th>
        </tr>
    </thead>
    <tbody>
        {% for order in recent_orders %}
        <tr>
            <td>#{{ order.id }}</td>
            <td>{{ order.customer_name|default('Guest') }}</td>
            <td><span class="cc-badge cc-badge-info">{{ order.status_label }}</span></td>
            <td>{{ order.total }} $</td>
            <td>{{ order.date_added }}</td>
        </tr>
        {% endfor %}
    </tbody>
</table>
{% else %}
    {% include '@admin/common/empty-state.html.twig' with {
        title: 'No orders yet',
        message: 'Orders will appear here when customers start placing purchases.'
    } %}
{% endif %}
{% endblock %}
