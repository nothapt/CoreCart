{% extends '@admin/layout/auth.html.twig' %}

{% block title %}Sign in — CoreCart Admin{% endblock %}

{% block content %}
<form method="post" action="/admin/login" class="cc-login-form">
    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

    <div class="cc-login-field">
        <label class="cc-login-label" for="login">Username</label>
        <div class="cc-login-input-group">
            <span class="cc-login-input-icon">
                <svg class="cc-icon" aria-hidden="true">
                    <use href="#cc-i-user"></use>
                </svg>
            </span>
            <input type="text"
                   id="login"
                   name="login"
                   class="cc-input cc-login-input"
                   autocomplete="username"
                   placeholder="Username or email"
                   required
                   autofocus>
        </div>
    </div>

    <div class="cc-login-field">
        <label class="cc-login-label" for="password">Password</label>
        <div class="cc-login-input-group">
            <span class="cc-login-input-icon">
                <svg class="cc-icon" aria-hidden="true">
                    <use href="#cc-i-lock"></use>
                </svg>
            </span>
            <input type="password"
                   id="password"
                   name="password"
                   class="cc-input cc-login-input"
                   autocomplete="current-password"
                   placeholder="Password"
                   required>
        </div>
    </div>

    <button type="submit" class="cc-btn cc-btn-primary cc-btn-block cc-login-submit">
        <svg class="cc-icon" aria-hidden="true">
            <use href="#cc-i-login"></use>
        </svg>
        Sign in
    </button>
</form>
{% endblock %}
