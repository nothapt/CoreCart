{% extends '@admin/layout/base.html.twig' %}
{% block title %}Categories — CoreCart Admin{% endblock %}
{% block content %}
<div class="cc-page-header">
    <div>
        <h1>Categories</h1>
        <p>Manage catalog categories.</p>
    </div>
    <a href="/admin/category/create" class="cc-btn cc-btn-primary">Add category</a>
</div>

{% if categories is defined and categories|length > 0 %}
<table class="cc-table">
    <thead>
        <tr><th>ID</th><th>Name</th><th>Status</th><th></th></tr>
    </thead>
    <tbody>
        {% for category in categories %}
        <tr>
            <td>{{ category.id }}</td>
            <td>{{ category.name }}</td>
            <td>
                {% if category.status == 1 %}
                    <span class="cc-badge cc-badge-success">Enabled</span>
                {% else %}
                    <span class="cc-badge cc-badge-neutral">Disabled</span>
                {% endif %}
            </td>
            <td><a href="/admin/category/edit?id={{ category.id }}" class="cc-btn cc-btn-secondary">Edit</a></td>
        </tr>
        {% endfor %}
    </tbody>
</table>
{% else %}
    {% include '@admin/common/empty-state.html.twig' with {
        title: 'No categories',
        message: 'Add the first category to organize the catalog.',
        action_url: '/admin/category/create',
        action_text: 'Add category'
    } %}
{% endif %}
{% endblock %}
