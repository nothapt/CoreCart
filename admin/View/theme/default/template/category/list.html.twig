{% extends '@admin/layout/base.html.twig' %}

{% block title %}Categories — CoreCart Admin{% endblock %}

{% block content %}
<header class="cc-content-header">
    <div>
        <h1>Categories</h1>
        <ol class="cc-breadcrumbs">
            <li><svg class="cc-icon"><use href="#cc-i-home"></use></svg></li>
            <li>Catalog</li>
            <li>Categories</li>
        </ol>
    </div>

    <div class="cc-content-actions">
        <a href="/admin/category/create" class="cc-btn cc-btn-primary" title="Add category">
            <svg class="cc-icon"><use href="#cc-i-plus"></use></svg>
        </a>
        <a href="/admin/category/index" class="cc-btn" title="Refresh">
            <svg class="cc-icon"><use href="#cc-i-refresh"></use></svg>
        </a>
    </div>
</header>

<div class="cc-content">
    <section class="cc-panel">
        <div class="cc-panel-heading">
            <svg class="cc-icon"><use href="#cc-i-list"></use></svg> Category list
        </div>

        {% if categories is defined and categories|length > 0 %}
            <div class="cc-table-wrap">
                <table class="cc-table">
                    <thead>
                        <tr>
                            <th class="cc-text-center" style="width:42px;">ID</th>
                            <th>Category</th>
                            <th>Status</th>
                            <th class="cc-text-right">Sort order</th>
                            <th class="cc-text-right" style="width:125px;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for category in categories %}
                            <tr>
                                <td class="cc-text-center">{{ category.id }}</td>
                                <td>
                                    <a href="/admin/category/edit?id={{ category.id }}">
                                        {{ category.name }}
                                    </a>
                                </td>
                                <td>
                                    {% if category.status == 1 %}
                                        <span class="cc-badge cc-badge-success">Enabled</span>
                                    {% else %}
                                        <span class="cc-badge cc-badge-neutral">Disabled</span>
                                    {% endif %}
                                </td>
                                <td class="cc-text-right">0</td>
                                <td class="cc-table-actions">
                                    <a href="/admin/category/edit?id={{ category.id }}"
                                       class="cc-btn cc-btn-primary cc-btn-sm"
                                       title="Edit">
                                        <svg class="cc-icon"><use href="#cc-i-edit"></use></svg>
                                    </a>

                                    <form method="post"
                                          action="/admin/category/delete"
                                          style="display:inline">
                                        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                                        <input type="hidden" name="category_id" value="{{ category.id }}">
                                        <button type="submit"
                                                class="cc-btn cc-btn-danger cc-btn-sm"
                                                data-confirm="Delete this category?"
                                                title="Delete">
                                            <svg class="cc-icon"><use href="#cc-i-trash"></use></svg>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% else %}
            {% include '@admin/common/empty-state.html.twig' with {
                title: 'No categories',
                message: 'Add the first category to organize the catalog.',
                action_url: '/admin/category/create',
                action_text: 'Add category'
            } %}
        {% endif %}
    </section>
</div>
{% endblock %}