{% extends '@admin/layout/base.html.twig' %}

{% set is_edit = category.id is defined and category.id > 0 %}

{% block title %}{{ is_edit ? 'Edit category' : 'Add category' }} — CoreCart Admin{% endblock %}

{% block content %}
<header class="cc-content-header">
    <div>
        <h1>{{ is_edit ? 'Edit category' : 'Add category' }}</h1>
        <ol class="cc-breadcrumbs">
            <li><svg class="cc-icon"><use href="#cc-i-home"></use></svg></li>
            <li>Catalog</li>
            <li><a href="/admin/category/index">Categories</a></li>
            <li>{{ is_edit ? 'Edit' : 'Add' }}</li>
        </ol>
    </div>

    <div class="cc-content-actions">
        <button type="submit" form="category-form" class="cc-btn cc-btn-primary" title="Save">
            <svg class="cc-icon"><use href="#cc-i-save"></use></svg>
        </button>
        <a href="/admin/category/index" class="cc-btn" title="Back">
            <svg class="cc-icon"><use href="#cc-i-back"></use></svg>
        </a>
    </div>
</header>

<div class="cc-content">
    <section class="cc-panel">
        <div class="cc-panel-heading">
            <svg class="cc-icon"><use href="#cc-i-edit"></use></svg>
            {{ is_edit ? 'Editing category' : 'Creating category' }}
        </div>

        <div class="cc-panel-body">
            <form id="category-form"
                  method="post"
                  action="/admin/category/{{ is_edit ? 'edit' : 'create' }}">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                {% if is_edit %}
                    <input type="hidden" name="category_id" value="{{ category.id }}">
                {% endif %}

                <div data-tabs>
                    <div class="cc-tabs">
                        <button type="button"
                                class="cc-tab-button active"
                                data-tab-target="general">
                            General
                        </button>
                        <button type="button"
                                class="cc-tab-button"
                                data-tab-target="data">
                            Data
                        </button>
                        <button type="button"
                                class="cc-tab-button"
                                data-tab-target="design">
                            Design
                        </button>
                    </div>

                    <div class="cc-tab-pane active" data-tab-pane="general">
                        <div class="cc-form-row">
                            <label class="cc-label cc-label-required" for="name">Category name</label>
                            <div>
                                <input type="text"
                                       id="name"
                                       name="name"
                                       class="cc-input"
                                       value="{{ category.name|default('') }}"
                                       required>
                            </div>
                        </div>
                    </div>

                    <div class="cc-tab-pane" data-tab-pane="data">
                        <div class="cc-form-row">
                            <label class="cc-label" for="parent_id">Parent category ID</label>
                            <div>
                                <input type="number"
                                       id="parent_id"
                                       name="parent_id"
                                       class="cc-input"
                                       min="0"
                                       value="{{ category.parentId|default(0) }}">
                                <div class="cc-help">Use 0 for a root category.</div>
                            </div>
                        </div>

                        <div class="cc-form-row">
                            <label class="cc-label" for="status">Status</label>
                            <div>
                                <select id="status" name="status" class="cc-input">
                                    <option value="1" {{ category.status|default(1) == 1 ? 'selected' : '' }}>
                                        Enabled
                                    </option>
                                    <option value="0" {{ category.status|default(1) == 0 ? 'selected' : '' }}>
                                        Disabled
                                    </option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="cc-tab-pane" data-tab-pane="design">
                        <div class="cc-alert cc-alert-info">
                            Layout assignment is intentionally not shown until layouts are implemented in CoreCart.
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </section>
</div>
{% endblock %}