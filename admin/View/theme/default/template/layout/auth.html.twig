<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Sign in — CoreCart Admin{% endblock %}</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="{{ assets.css('admin-tokens.css') }}">
    <link rel="stylesheet" href="{{ assets.css('admin-base.css') }}">
    {% block head %}{% endblock %}
</head>
<body class="cc-admin-auth">
    <div class="cc-admin-auth-wrapper">
        {% include '@admin/common/flash.html.twig' %}
        {% block content %}{% endblock %}
        <p class="cc-text-center cc-mt-4 cc-text-sm">
            <a href="/" class="cc-footer-link">Back to store</a>
        </p>
    </div>
</body>
</html>
