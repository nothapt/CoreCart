{% extends '@admin/layout/base.html.twig' %}
{% block title %}Заказ #{{ order.id }} — CoreCart Admin{% endblock %}
{% block content %}
<div class="cc-page-header">
    <div>
        <h1>Заказ #{{ order.id }}</h1>
        <p>{{ order.date_added }}</p>
    </div>
    <a href="/admin/order/index" class="cc-btn cc-btn-secondary">Назад к списку</a>
</div>

<div style="display:grid;grid-template-columns:1fr 360px;gap:var(--cc-space-6);">
    <div>
        <div class="cc-card cc-card-body cc-mb-4">
            <h3 class="cc-mb-4">Товары</h3>
            <table class="cc-table">
                <thead><tr><th>Товар</th><th>Кол-во</th><th>Цена</th><th>Итого</th></tr></thead>
                <tbody>
                    {% for item in order.items %}
                    <tr>
                        <td>{{ item.name }}</td>
                        <td>{{ item.quantity }}</td>
                        <td>{{ item.price }} ₽</td>
                        <td>{{ item.total }} ₽</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    <div>
        <div class="cc-card cc-card-body cc-mb-4">
            <h3 class="cc-mb-4">Покупатель</h3>
            <p class="cc-text-sm"><strong>Email:</strong> {{ order.email|default('—') }}</p>
            <p class="cc-text-sm"><strong>Телефон:</strong> {{ order.phone|default('—') }}</p>
        </div>
        <div class="cc-card cc-card-body cc-mb-4">
            <h3 class="cc-mb-4">Адрес доставки</h3>
            <p class="cc-text-sm">
                {{ order.shipping_firstname|default('') }} {{ order.shipping_lastname|default('') }}<br>
                {{ order.shipping_address_1|default('') }}<br>
                {{ order.shipping_city|default('') }}, {{ order.shipping_postcode|default('') }}<br>
                {{ order.shipping_country|default('') }}
            </p>
        </div>
        <div class="cc-card cc-card-body">
            <h3 class="cc-mb-4">Итоги</h3>
            <div class="cc-flex cc-justify-between cc-mb-2"><span class="cc-text-muted">Статус:</span><span class="cc-badge cc-badge-info">{{ order.status_label }}</span></div>
            <div class="cc-flex cc-justify-between cc-mb-2"><span class="cc-text-muted">Итого:</span><strong>{{ order.total }} ₽</strong></div>
        </div>

        <div class="cc-card cc-card-body cc-mt-4">
            <h3 class="cc-mb-4">Изменить статус</h3>
            <form method="post" action="/admin/order/updateStatus">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token|default('') }}">
                <input type="hidden" name="order_id" value="{{ order.id }}">
                <div class="cc-field">
                    <label class="cc-label" for="status">Новый статус</label>
                    <select id="status" name="status" class="cc-input">
                        <option value="1">Pending</option>
                        <option value="2">Processing</option>
                        <option value="3">Shipped</option>
                        <option value="4">Delivered</option>
                        <option value="9">Cancelled</option>
                    </select>
                </div>
                <div class="cc-field">
                    <label class="cc-label" for="comment">Комментарий</label>
                    <textarea id="comment" name="comment" class="cc-input" rows="3"></textarea>
                </div>
                <button type="submit" class="cc-btn cc-btn-primary">Обновить статус</button>
            </form>
        </div>
    </div>
</div>
{% endblock %}
