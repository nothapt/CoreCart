{% extends '@admin/layout/base.html.twig' %}
{% block title %}Settings — CoreCart Admin{% endblock %}
{% block content %}
<header class="cc-content-header">
    <div>
        <h1>Settings</h1>
        <ol class="cc-breadcrumbs">
            <li><svg class="cc-icon"><use href="#cc-i-home"></use></svg></li>
            <li>System</li>
            <li>Settings</li>
        </ol>
    </div>
</header>

<div class="cc-content">
    <section class="cc-panel">
        <div class="cc-panel-heading">
            <svg class="cc-icon"><use href="#cc-i-settings"></use></svg>
            Store Settings
        </div>

        <div class="cc-panel-body">
            <div data-tabs>
                <div class="cc-tabs">
                    <button type="button"
                            class="cc-tab-button active"
                            data-tab-target="store">
                        Store
                    </button>
                    <button type="button"
                            class="cc-tab-button"
                            data-tab-target="local">
                        Local
                    </button>
                    <button type="button"
                            class="cc-tab-button"
                            data-tab-target="security">
                        Security
                    </button>
                    <button type="button"
                            class="cc-tab-button"
                            data-tab-target="mail">
                        Mail
                    </button>
                </div>

                <div class="cc-tab-pane active" data-tab-pane="store">
                    <form method="post" action="/admin/setting/store">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

                        <div class="cc-form-row">
                            <label class="cc-label" for="store_name">Store Name</label>
                            <div>
                                <input type="text"
                                       id="store_name"
                                       name="store_name"
                                       class="cc-input"
                                       value="{{ settings.name|default('CoreCart') }}">
                            </div>
                        </div>

                        <div class="cc-form-row">
                            <label class="cc-label" for="store_owner">Store Owner</label>
                            <div>
                                <input type="text"
                                       id="store_owner"
                                       name="store_owner"
                                       class="cc-input"
                                       value="{{ settings.owner|default('') }}">
                            </div>
                        </div>

                        <div class="cc-form-row">
                            <label class="cc-label" for="store_address">Store Address</label>
                            <div>
                                <textarea id="store_address"
                                          name="store_address"
                                          class="cc-input"
                                          rows="3">{{ settings.address|default('') }}</textarea>
                            </div>
                        </div>

                        <div class="cc-form-row">
                            <label class="cc-label" for="store_email">Email</label>
                            <div>
                                <input type="email"
                                       id="store_email"
                                       name="store_email"
                                       class="cc-input"
                                       value="{{ settings.email|default('') }}">
                            </div>
                        </div>

                        <div class="cc-form-row">
                            <label class="cc-label" for="store_phone">Phone</label>
                            <div>
                                <input type="text"
                                       id="store_phone"
                                       name="store_phone"
                                       class="cc-input"
                                       value="{{ settings.phone|default('') }}">
                            </div>
                        </div>

                        <div class="cc-form-row">
                            <label class="cc-label" for="meta_title">Meta Title</label>
                            <div>
                                <input type="text"
                                       id="meta_title"
                                       name="meta_title"
                                       class="cc-input"
                                       value="{{ meta.title|default('') }}">
                            </div>
                        </div>

                        <div class="cc-form-row">
                            <label class="cc-label" for="meta_description">Meta Description</label>
                            <div>
                                <textarea id="meta_description"
                                          name="meta_description"
                                          class="cc-input"
                                          rows="3">{{ meta.description|default('') }}</textarea>
                            </div>
                        </div>

                        <div class="cc-form-row">
                            <label class="cc-label" for="maintenance">Maintenance Mode</label>
                            <div>
                                <select id="maintenance" name="maintenance" class="cc-input">
                                    <option value="0" {{ settings.maintenance|default('0') == '0' ? 'selected' : '' }}>Disabled</option>
                                    <option value="1" {{ settings.maintenance|default('0') == '1' ? 'selected' : '' }}>Enabled</option>
                                </select>
                            </div>
                        </div>

                        <div class="cc-form-actions">
                            <button type="submit" class="cc-btn cc-btn-primary">Save Store Settings</button>
                        </div>
                    </form>
                </div>

                <div class="cc-tab-pane" data-tab-pane="local">
                    <form method="post" action="/admin/setting/local">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

                        <div class="cc-form-row">
                            <label class="cc-label" for="language">Language</label>
                            <div>
                                <select id="language" name="language" class="cc-input">
                                    <option value="en-gb" {{ local.language|default('en-gb') == 'en-gb' ? 'selected' : '' }}>English</option>
                                    <option value="ru-ru" {{ local.language|default('en-gb') == 'ru-ru' ? 'selected' : '' }}>Русский</option>
                                </select>
                            </div>
                        </div>

                        <div class="cc-form-row">
                            <label class="cc-label" for="currency">Currency</label>
                            <div>
                                <select id="currency" name="currency" class="cc-input">
                                    <option value="USD" {{ local.currency|default('USD') == 'USD' ? 'selected' : '' }}>USD — US Dollar</option>
                                    <option value="EUR" {{ local.currency|default('USD') == 'EUR' ? 'selected' : '' }}>EUR — Euro</option>
                                    <option value="RUB" {{ local.currency|default('USD') == 'RUB' ? 'selected' : '' }}>RUB — Russian Ruble</option>
                                </select>
                            </div>
                        </div>

                        <div class="cc-form-row">
                            <label class="cc-label" for="timezone">Timezone</label>
                            <div>
                                <select id="timezone" name="timezone" class="cc-input">
                                    <option value="UTC" {{ local.timezone|default('UTC') == 'UTC' ? 'selected' : '' }}>UTC</option>
                                    <option value="Europe/Moscow" {{ local.timezone|default('UTC') == 'Europe/Moscow' ? 'selected' : '' }}>Moscow (UTC+3)</option>
                                    <option value="Europe/London" {{ local.timezone|default('UTC') == 'Europe/London' ? 'selected' : '' }}>London (UTC+0/+1)</option>
                                    <option value="America/New_York" {{ local.timezone|default('UTC') == 'America/New_York' ? 'selected' : '' }}>New York (UTC-5/-4)</option>
                                    <option value="Asia/Tokyo" {{ local.timezone|default('UTC') == 'Asia/Tokyo' ? 'selected' : '' }}>Tokyo (UTC+9)</option>
                                </select>
                            </div>
                        </div>

                        <div class="cc-form-actions">
                            <button type="submit" class="cc-btn cc-btn-primary">Save Local Settings</button>
                        </div>
                    </form>
                </div>

                <div class="cc-tab-pane" data-tab-pane="security">
                    <form method="post" action="/admin/setting/security">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

                        <div class="cc-form-row">
                            <label class="cc-label" for="password_attempts">Max Password Attempts</label>
                            <div>
                                <input type="number"
                                       id="password_attempts"
                                       name="password_attempts"
                                       class="cc-input"
                                       min="1"
                                       max="100"
                                       value="{{ security.password_attempts|default('5') }}">
                                <div class="cc-help">Number of failed login attempts before lockout.</div>
                            </div>
                        </div>

                        <div class="cc-form-row">
                            <label class="cc-label" for="lockout_duration">Lockout Duration (minutes)</label>
                            <div>
                                <input type="number"
                                       id="lockout_duration"
                                       name="lockout_duration"
                                       class="cc-input"
                                       min="1"
                                       max="1440"
                                       value="{{ security.lockout_duration|default('15') }}">
                                <div class="cc-help">How long the user is locked out after max attempts.</div>
                            </div>
                        </div>

                        <div class="cc-form-row">
                            <label class="cc-label" for="session_timeout">Session Timeout (seconds)</label>
                            <div>
                                <input type="number"
                                       id="session_timeout"
                                       name="session_timeout"
                                       class="cc-input"
                                       min="300"
                                       max="86400"
                                       value="{{ security.session_timeout|default('3600') }}">
                                <div class="cc-help">Idle time before admin session expires. Default: 3600 (1 hour).</div>
                            </div>
                        </div>

                        <div class="cc-form-actions">
                            <button type="submit" class="cc-btn cc-btn-primary">Save Security Settings</button>
                        </div>
                    </form>
                </div>

                <div class="cc-tab-pane" data-tab-pane="mail">
                    <form method="post" action="/admin/setting/mail">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

                        <div class="cc-form-row">
                            <label class="cc-label" for="mail_protocol">Mail Protocol</label>
                            <div>
                                <select id="mail_protocol" name="mail_protocol" class="cc-input">
                                    <option value="smtp" {{ mail.protocol|default('smtp') == 'smtp' ? 'selected' : '' }}>SMTP</option>
                                    <option value="mail" {{ mail.protocol|default('smtp') == 'mail' ? 'selected' : '' }}>PHP Mail</option>
                                </select>
                            </div>
                        </div>

                        <div class="cc-form-row">
                            <label class="cc-label" for="smtp_host">SMTP Host</label>
                            <div>
                                <input type="text"
                                       id="smtp_host"
                                       name="smtp_host"
                                       class="cc-input"
                                       value="{{ mail.smtp_host|default('') }}">
                            </div>
                        </div>

                        <div class="cc-form-row">
                            <label class="cc-label" for="smtp_port">SMTP Port</label>
                            <div>
                                <input type="number"
                                       id="smtp_port"
                                       name="smtp_port"
                                       class="cc-input"
                                       min="1"
                                       max="65535"
                                       value="{{ mail.smtp_port|default('587') }}">
                            </div>
                        </div>

                        <div class="cc-form-row">
                            <label class="cc-label" for="smtp_username">SMTP Username</label>
                            <div>
                                <input type="text"
                                       id="smtp_username"
                                       name="smtp_username"
                                       class="cc-input"
                                       value="{{ mail.smtp_username|default('') }}">
                            </div>
                        </div>

                        <div class="cc-form-row">
                            <label class="cc-label" for="smtp_password">SMTP Password</label>
                            <div>
                                <input type="password"
                                       id="smtp_password"
                                       name="smtp_password"
                                       class="cc-input"
                                       value="">
                                <div class="cc-help">Leave empty to keep current password unchanged.</div>
                            </div>
                        </div>

                        <div class="cc-form-actions">
                            <button type="submit" class="cc-btn cc-btn-primary">Save Mail Settings</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </section>
</div>
{% endblock %}
