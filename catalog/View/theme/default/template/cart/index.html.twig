{% extends '@storefront/layout/base.html.twig' %}

{% block title %}Cart — CoreCart{% endblock %}

{% block content %}
<h1 class="cc-mb-4">Cart</h1>

{% if items is defined and items|length > 0 %}
<div class="cc-cart-layout">
    <div>
        {% for item in items %}
        <div class="cc-card cc-card-body cc-mb-2 cc-cart-item">
            <div class="cc-cart-item-image"></div>
            <div class="cc-flex-1">
                <div class="cc-font-bold">{{ item.name }}</div>
                <div class="cc-text-muted cc-text-sm">{{ item.price }} $</div>
            </div>
            <form method="post" action="/cart/update" class="cc-flex cc-items-center cc-gap-2">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token|default('') }}">
                <input type="hidden" name="cart_id" value="{{ item.cart_id }}">
                <input type="number" name="quantity" value="{{ item.quantity }}" min="1" class="cc-input cc-input-sm">
                <button type="submit" class="cc-btn cc-btn-secondary">Update</button>
            </form>
            <div class="cc-font-bold cc-nowrap">{{ item.total }} $</div>
            <form method="post" action="/cart/remove">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token|default('') }}">
                <input type="hidden" name="cart_id" value="{{ item.cart_id }}">
                <button type="submit" class="cc-btn cc-btn-link cc-text-muted">Remove</button>
            </form>
        </div>
        {% endfor %}
    </div>
    <div>
        <div class="cc-card cc-card-body">
            <h3 class="cc-mb-4">Summary</h3>
            <div class="cc-flex cc-justify-between cc-mb-2">
                <span class="cc-text-muted">Subtotal:</span>
                <span>{{ total }} $</span>
            </div>
            <div class="cc-flex cc-justify-between cc-mb-4">
                <span class="cc-text-muted">Shipping:</span>
                <span>—</span>
            </div>
            <hr>
            <div class="cc-flex cc-justify-between cc-mb-4">
                <strong>Total:</strong>
                <strong>{{ total }} $</strong>
            </div>
            <a href="/checkout" class="cc-btn cc-btn-primary cc-btn-block">Checkout</a>
            <a href="/catalog" class="cc-btn cc-btn-secondary cc-btn-block cc-mt-2">Continue shopping</a>
        </div>
    </div>
</div>
{% else %}
    {% include '@storefront/common/empty-state.html.twig' with {
        title: 'Cart is empty',
        message: 'Add products from the catalog to place an order.',
        action_url: '/catalog',
        action_text: 'Browse catalog'
    } %}
{% endif %}
{% endblock %}
