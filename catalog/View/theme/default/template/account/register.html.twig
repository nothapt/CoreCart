{% extends '@storefront/layout/base.html.twig' %}

{% block title %}Register — CoreCart{% endblock %}

{% block content %}
<div class="cc-auth-wrapper">
    <div class="cc-card cc-card-body">
        <h1 class="cc-mb-4 cc-text-center">Create account</h1>
        <form method="post" action="/account/register">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token|default('') }}">

            <div class="cc-field">
                <label class="cc-label" for="firstname">First name</label>
                <input type="text" id="firstname" name="firstname" class="cc-input" required>
            </div>

            <div class="cc-field">
                <label class="cc-label" for="lastname">Last name</label>
                <input type="text" id="lastname" name="lastname" class="cc-input" required>
            </div>

            <div class="cc-field">
                <label class="cc-label" for="email">Email</label>
                <input type="email" id="email" name="email" class="cc-input" required>
            </div>

            <div class="cc-field">
                <label class="cc-label" for="password">Password</label>
                <input type="password" id="password" name="password" class="cc-input" required minlength="6">
            </div>

            <button type="submit" class="cc-btn cc-btn-primary cc-btn-block">Create account</button>
        </form>
        <p class="cc-text-center cc-mt-4 cc-text-sm">
            Already have an account? <a href="/account/login">Sign in</a>
        </p>
    </div>
</div>
{% endblock %}
