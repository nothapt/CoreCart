{% extends '@storefront/layout/base.html.twig' %}

{% block title %}{{ product.name }} — CoreCart{% endblock %}

{% block content %}
{% include '@storefront/common/breadcrumbs.html.twig' %}

<div class="cc-product-page">
    <div class="cc-product-image">
        {% if product.image %}
            <img src="{{ product.image }}" alt="{{ product.name }}">
        {% endif %}
    </div>
    <div>
        <h1 class="cc-mb-2">{{ product.name }}</h1>
        <div class="cc-product-card-price cc-mb-2">{{ product.price }} $</div>
        {% if product.stock_status is defined %}
            <span class="cc-badge cc-badge-success cc-mb-4 cc-d-block">In stock</span>
        {% endif %}

        <form method="post" action="/cart/add" class="cc-mt-4">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token|default('') }}">
            <input type="hidden" name="product_id" value="{{ product.id }}">
            <div class="cc-field">
                <label class="cc-label" for="quantity">Quantity</label>
                <input type="number" id="quantity" name="quantity" value="1" min="1" class="cc-input cc-input-md">
            </div>
            <button type="submit" class="cc-btn cc-btn-primary cc-btn-lg">Add to cart</button>
        </form>
    </div>
</div>

{% if product.description is defined and product.description %}
<div class="cc-mt-8">
    <h2>Description</h2>
    <div>{{ product.description|raw }}</div>
</div>
{% endif %}
{% endblock %}
