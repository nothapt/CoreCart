{% if breadcrumbs is defined and breadcrumbs|length > 0 %}
<nav aria-label="Breadcrumb" class="cc-text-sm cc-text-muted cc-mb-4">
    <ol class="cc-breadcrumbs">
        <li><a href="/" class="cc-footer-link">Home</a></li>
        {% for crumb in breadcrumbs %}
            <li aria-hidden="true">/</li>
            {% if crumb.url is defined and crumb.url %}
                <li><a href="{{ crumb.url }}" class="cc-footer-link">{{ crumb.name }}</a></li>
            {% else %}
                <li>{{ crumb.name }}</li>
            {% endif %}
        {% endfor %}
    </ol>
</nav>
{% endif %}
