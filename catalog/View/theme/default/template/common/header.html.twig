<header class="cc-header">
    <div class="cc-container cc-header-inner">
        <a href="/" class="cc-logo">CoreCart</a>

        <a href="/catalog" class="cc-header-link">Каталог</a>

        <form action="/search" method="get" class="cc-search">
            <input
                type="search"
                name="q"
                class="cc-search-input"
                placeholder="Поиск товаров..."
                value="{{ app.request.query.get('q')|default('') }}"
                aria-label="Поиск товаров"
            >
        </form>

        <nav class="cc-header-nav" aria-label="Основная навигация">
            {% if app.user is defined and app.user %}
                <a href="/account" class="cc-header-link">Аккаунт</a>
            {% else %}
                <a href="/account/login" class="cc-header-link">Войти</a>
            {% endif %}

            <a href="/cart" class="cc-header-link">
                Корзина
                {% if cart_count is defined and cart_count > 0 %}
                    <span class="cc-cart-count">{{ cart_count }}</span>
                {% endif %}
            </a>
        </nav>
    </div>
</header>
