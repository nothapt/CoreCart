<div class="cc-empty">
    <div class="cc-empty-title">{{ title|default('Nothing here') }}</div>
    <p>{{ message|default('Nothing to display.') }}</p>
    {% if action_url is defined and action_url %}
        <a href="{{ action_url }}" class="cc-btn cc-btn-primary">{{ action_text|default('Go') }}</a>
    {% endif %}
</div>
