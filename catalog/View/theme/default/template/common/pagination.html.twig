{% if pages is defined and pages > 1 %}
<nav aria-label="Pagination" class="cc-mt-8 cc-text-center">
    <ul class="cc-pagination">
        {% for p in 1..pages %}
            <li>
                {% if p == current_page|default(1) %}
                    <span class="cc-btn cc-btn-primary" aria-current="page">{{ p }}</span>
                {% else %}
                    <a href="{{ base_url|default('?') }}?page={{ p }}" class="cc-btn cc-btn-secondary">{{ p }}</a>
                {% endif %}
            </li>
        {% endfor %}
    </ul>
</nav>
{% endif %}
