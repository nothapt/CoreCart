{% extends '@storefront/layout/base.html.twig' %}

{% block title %}Sign in — CoreCart{% endblock %}

{% block content %}
<div class="cc-auth-wrapper">
    <div class="cc-card cc-card-body">
        <h1 class="cc-mb-4 cc-text-center">Sign in</h1>
        <form method="post" action="/account/login">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token|default('') }}">

            <div class="cc-field">
                <label class="cc-label" for="email">Email</label>
                <input type="email" id="email" name="email" class="cc-input" required autofocus>
            </div>

            <div class="cc-field">
                <label class="cc-label" for="password">Password</label>
                <input type="password" id="password" name="password" class="cc-input" required>
            </div>

            <button type="submit" class="cc-btn cc-btn-primary cc-btn-block">Sign in</button>
        </form>
        <p class="cc-text-center cc-mt-4 cc-text-sm">
            Don't have an account? <a href="/account/register">Create one</a>
        </p>
    </div>
</div>
{% endblock %}
